{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ShabasherDbContext": "${DB_CONNECTION_STRING}"
  },
  "JwtOptions": {
    "SecretKey": "${JWT_SECRET}",
    "AccessTokenExpiresMinutes": "${JWT_ACCESS_MINUTES}",
    "RefreshTokenExpirationDays": "${JWT_REFRESH_DAYS}"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5000"
      }
    }
  }
}